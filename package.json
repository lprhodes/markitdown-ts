{
  "name": "@lprhodes/markitdown-ts",
  "version": "0.1.0",
  "description": "Convert documents to Markdown — TypeScript port of Microsoft markitdown",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^1.0.0",
    "@azure-rest/ai-document-intelligence": "^1.0.0",
    "@azure/identity": "^4.0.0",
    "ai": "^4.0.0",
    "cfb": "^1.2.0",
    "chardet": "^2.0.0",
    "cheerio": "^1.0.0",
    "exceljs": "^4.0.0",
    "exiftool-vendored": "^28.0.0",
    "fast-xml-parser": "^4.0.0",
    "file-type": "^19.0.0",
    "fluent-ffmpeg": "^2.1.0",
    "jszip": "^3.10.0",
    "mammoth": "^1.11.0",
    "papaparse": "^5.0.0",
    "pdfjs-dist": "^4.0.0",
    "turndown": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "pdfjs-dist": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "jszip": {
      "optional": true
    },
    "fast-xml-parser": {
      "optional": true
    },
    "exceljs": {
      "optional": true
    },
    "cheerio": {
      "optional": true
    },
    "turndown": {
      "optional": true
    },
    "papaparse": {
      "optional": true
    },
    "cfb": {
      "optional": true
    },
    "chardet": {
      "optional": true
    },
    "file-type": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "@ai-sdk/provider": {
      "optional": true
    },
    "@azure-rest/ai-document-intelligence": {
      "optional": true
    },
    "@azure/identity": {
      "optional": true
    },
    "exiftool-vendored": {
      "optional": true
    },
    "fluent-ffmpeg": {
      "optional": true
    }
  },
  "keywords": [
    "markdown",
    "converter",
    "pdf",
    "docx",
    "pptx",
    "xlsx",
    "html",
    "epub"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "devDependencies": {
    "@ai-sdk/provider": "^1.1.3",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
